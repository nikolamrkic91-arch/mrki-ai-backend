# =============================================================================
# Mrki Environment Variables Template
# =============================================================================
# Copy this file to .env and customize for your environment
# =============================================================================

# =============================================================================
# Core Configuration
# =============================================================================

# Server Configuration
MRKI_SERVER_HOST=0.0.0.0
MRKI_SERVER_PORT=8080
MRKI_SERVER_DEBUG=false
MRKI_SERVER_WORKERS=4

# Logging
MRKI_LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Configuration file path
MRKI_CONFIG_PATH=./config.yaml

# =============================================================================
# Security
# =============================================================================

# IMPORTANT: Change this to a secure random key in production!
# Generate with: openssl rand -hex 32
MRKI_SECRET_KEY=change-this-to-a-secure-random-key-in-production

# JWT Configuration
MRKI_JWT_ALGORITHM=HS256
MRKI_JWT_EXPIRATION=3600
MRKI_REFRESH_EXPIRATION=604800

# API Key (optional, for external service integration)
MRKI_API_KEY=

# =============================================================================
# Database
# =============================================================================

# PostgreSQL Configuration
POSTGRES_USER=mrki
POSTGRES_PASSWORD=mrki_secure_password
POSTGRES_DB=mrki
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL (overrides individual settings)
# Format: postgresql://user:password@host:port/database
MRKI_DATABASE_URL=postgresql://mrki:mrki_secure_password@localhost:5432/mrki

# Connection pool settings
MRKI_DB_POOL_SIZE=5
MRKI_DB_MAX_OVERFLOW=10
MRKI_DB_POOL_TIMEOUT=30

# =============================================================================
# Redis
# =============================================================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_DB=0

# Full Redis URL (overrides individual settings)
# Format: redis://[:password@]host:port/db
MRKI_REDIS_URL=redis://:redis_secure_password@localhost:6379/0

# Celery/RedBeat Redis URL (separate DB for scheduling)
REDBEAT_REDIS_URL=redis://:redis_secure_password@localhost:6379/1

# =============================================================================
# Object Storage (MinIO/S3)
# =============================================================================

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secure_password
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=mrki
MINIO_SECURE=false

# AWS S3 Configuration (if using S3 instead of MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=mrki

# =============================================================================
# Module Configuration
# =============================================================================

# Enable/Disable Modules
MRKI_CORE_ENABLED=true
MRKI_VISUAL_ENABLED=true
MRKI_DEV_ENV_ENABLED=true
MRKI_MOE_ENABLED=true
MRKI_GAMEDEV_ENABLED=true
MRKI_IDE_ENABLED=true

# =============================================================================
# Visual Engine Configuration
# =============================================================================

# Visual Engine Service
VISUAL_ENGINE_PORT=8001
VISUAL_ENGINE_HOST=localhost
VISUAL_ENGINE_MODEL_PATH=./models/visual

# Model Configuration
VISUAL_MODEL_NAME=default
VISUAL_MODEL_DEVICE=cpu
# Options: cpu, cuda, mps (Apple Silicon)

# GPU Configuration (if using CUDA)
CUDA_VISIBLE_DEVICES=0
VISUAL_BATCH_SIZE=4

# =============================================================================
# MoE (Mixture of Experts) Configuration
# =============================================================================

# MoE Service
MOE_PORT=8003
MOE_HOST=localhost
MOE_MODEL_PATH=./models/moe

# Model Configuration
MOE_NUM_EXPERTS=64
MOE_TOP_K=2
MOE_CAPACITY_FACTOR=1.25
MOE_ROUTING_STRATEGY=top_k
# Options: top_k, expert_choice, capacity_based, learned, hybrid

# Training Configuration
MOE_TRAINING_ENABLED=false
MOE_TRAINING_DATA_PATH=./data/training

# =============================================================================
# Game Development Configuration
# =============================================================================

# GameDev Service
GAMEDEV_PORT=8004
GAMEDEV_HOST=localhost
GAMEDEV_TEMPLATES_PATH=./templates/gamedev

# Engine Paths (for local development)
UNITY_PATH=
UNREAL_PATH=
GODOT_PATH=

# =============================================================================
# IDE Integration Configuration
# =============================================================================

# IDE Server
IDE_PORT=8005
IDE_WS_PORT=8006
IDE_HOST=localhost
IDE_PROJECTS_PATH=./projects

# LSP Configuration
LSP_ENABLED=true
LSP_PORT=9000

# DAP Configuration
DAP_ENABLED=true
DAP_PORT=9001

# =============================================================================
# External Services
# =============================================================================

# OpenAI API (for LLM features)
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4

# Anthropic API (for Claude integration)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Google AI (for Gemini integration)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro

# Hugging Face (for model downloads)
HF_TOKEN=
HF_CACHE_DIR=./models/huggingface

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Jaeger Tracing
JAEGER_ENABLED=true
JAEGER_PORT=16686
JAEGER_OTLP_PORT=4317

# Sentry (for error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# Development Tools
# =============================================================================

# pgAdmin
PGADMIN_EMAIL=admin@mrki.local
PGADMIN_PASSWORD=admin

# MailHog
MAILHOG_ENABLED=true
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# =============================================================================
# Testing
# =============================================================================

# Test Database (separate from main)
TEST_DATABASE_URL=postgresql://mrki:mrki_secure_password@localhost:5432/mrki_test

# Test Redis
TEST_REDIS_URL=redis://:redis_secure_password@localhost:6379/15

# Pytest Configuration
PYTEST_WORKERS=auto
PYTEST_COVERAGE=true

# =============================================================================
# Docker Configuration
# =============================================================================

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=mrki

# Docker Network
DOCKER_NETWORK=mrki_network

# Volume Paths (for bind mounts)
DOCKER_DATA_PATH=./data
DOCKER_LOGS_PATH=./logs
DOCKER_MODELS_PATH=./models

# =============================================================================
# Feature Flags
# =============================================================================

# Experimental Features
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_BETA_AGENTS=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Caching
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=10000

# =============================================================================
# Deployment
# =============================================================================

# Environment
ENVIRONMENT=development
# Options: development, staging, production

# Version
MRKI_VERSION=1.0.0

# Git
GIT_COMMIT=
GIT_BRANCH=

# =============================================================================
# Advanced Configuration
# =============================================================================

# Async Settings
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30

# Worker Settings
CELERY_WORKERS=4
CELERY_MAX_TASKS_PER_CHILD=1000

# Memory Limits (in MB)
MAX_MEMORY_API=8192
MAX_MEMORY_VISUAL=8192
MAX_MEMORY_MOE=16384

# =============================================================================
# Notes
# =============================================================================
# 
# 1. Never commit the actual .env file to version control!
# 2. Use strong, unique passwords for all services in production
# 3. Rotate secrets regularly
# 4. Use environment-specific values for different deployments
# 5. Keep this template updated when adding new configuration options
#
# =============================================================================
