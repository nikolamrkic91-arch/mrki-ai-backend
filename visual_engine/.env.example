# Mrki Visual Engine - Environment Variables
# ===========================================

# Vision Model Configuration
MRKI_VISION_MODEL=default
# Options: default, gpt4v, claude

# Default Code Generation Settings
MRKI_DEFAULT_FRAMEWORK=react
# Options: react, vue, angular, svelte

MRKI_DEFAULT_STYLE_SYSTEM=tailwind
# Options: tailwind, css_modules, styled_components, scss, plain_css

# API Server Configuration
MRKI_API_HOST=0.0.0.0
MRKI_API_PORT=8000
MRKI_LOG_LEVEL=info
# Options: debug, info, warning, error, critical

# File Upload Settings
MRKI_MAX_FILE_SIZE=10485760
# 10MB in bytes

# Optional: Figma API Token (for Figma import)
# FIGMA_API_TOKEN=your_figma_api_token_here

# Optional: OpenAI API Key (for GPT-4V integration)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (for Claude Vision integration)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
